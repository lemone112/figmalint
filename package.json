{
  "name": "bezier",
  "version": "2.4.0",
  "description": "Bezier - Component linting for Figma that audits design system compliance, MCP compatibility, accessibility, and generates developer handoff documentation.",
  "main": "dist/code.js",
  "scripts": {
    "build": "npm run bundle && npm run build:ui && npm run copy-assets",
    "bundle": "esbuild src/code.ts --bundle --outfile=dist/code.js --platform=neutral --target=es2017 --format=iife --loader:.ts=ts --minify --main-fields=module,main",
    "build:ui": "npm --prefix ui run build",
    "dev": "npm run bundle -- --watch",
    "copy-assets": "cp manifest.json dist/",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "prebuild": "npm run clean"
  },
  "keywords": [
    "figma",
    "plugin",
    "linter",
    "lint",
    "audit",
    "mcp",
    "design-system",
    "accessibility",
    "tokens",
    "developer-handoff"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@figma/plugin-typings": "^1.114.0",
    "@types/lz-string": "^1.3.34",
    "esbuild": "^0.25.5",
    "typescript": "^5.6.3",
    "vitest": "^4.1.0"
  },
  "files": [
    "dist/**/*"
  ],
  "dependencies": {
    "lz-string": "^1.5.0"
  }
}
