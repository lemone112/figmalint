# Required: Anthropic API key for Claude AI analysis
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: Server port (default: 3000)
PORT=3000

# Optional: SQLite database path (default: ./data/sessions.db)
# DATABASE_PATH=./data/sessions.db

# Optional: Bearer token for API authentication (recommended for production)
# When set, all /api/* requests (except /api/health) require Authorization: Bearer <token>
# BACKEND_AUTH_TOKEN=your-secret-token-here

# Optional: Rate limit — max requests per IP per window (default: 60 per minute)
# RATE_LIMIT_MAX=60
# RATE_LIMIT_WINDOW_MS=60000
